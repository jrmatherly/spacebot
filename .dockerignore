target/
.git/
.DS_Store
.fastembed_cache/
.github/

# Frontend build artifacts (rebuilt in Docker)
interface/node_modules/
interface/dist/

# SpaceUI build artifacts (source copied explicitly in Dockerfile)
spaceui/node_modules/
spaceui/packages/*/dist/
spaceui/packages/*/node_modules/
spaceui/examples/
# Bun workspace resolver requires every declared member's package.json
# to exist during install; allow stubs through even though examples/ and
# .storybook/ are otherwise dev-only.
!spaceui/examples/*/package.json
spaceui/.storybook/
!spaceui/.storybook/package.json
spaceui/.changeset/
spaceui/scripts/

# Not needed for the server build
tests/
scripts/
!scripts/build-opencode-embed.sh
!scripts/check-workspace-protocol.sh
desktop/
# Exclude packages/ by default, but allow @spacebot/api-client through
# because interface/package.json declares it as a workspace member
# (`"workspaces": ["../packages/*"]`) and `bun install` must resolve
# `@spacebot/api-client@workspace:*` to its on-disk source.
packages/
!packages/api-client/
spacedrive/

# Exclude docs except what's needed for self_awareness.rs embeds
# (embeds: docs/README.md, docs/docker.md, docs/metrics.md)
docs/node_modules/
docs/.next/
docs/out/
docs/app/
docs/components/
docs/lib/
docs/design-docs/
docs/*.json
docs/*.ts
docs/*.tsx
docs/*.mjs
docs/*.yaml
docs/*.lock
docs/.gitignore
docs/.node-version

# Root files not needed for build
# (only AGENTS.md, README.md, CHANGELOG.md are embedded via self_awareness.rs)
fly.toml
fly.staging.toml
CONTRIBUTING.md
METRICS.md
RUST_STYLE_GUIDE.md
CLAUDE.md
PROJECT_INDEX.md
TODO
LICENSE

# Dev tooling
.cargo/
.githooks/
.envrc
.taplo.toml
rust-toolchain.toml
justfile

# Nix
flake.nix
flake.lock
nix/

# AI/editor tools
.claude/
.code-review-graph/
.codex/
.full-review/
.remember/
.serena/
.scratchpad/
.vscode/
.windsurf/
.worktrees/
openspec/
