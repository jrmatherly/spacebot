# ========================================
# Required: at least ONE LLM provider
# ========================================
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...
# (See docs/ for the full provider list)

# ========================================
# Spacebot image (digest-pinned)
# ========================================
# Tag kept as a human reference; Compose uses the digest below.
SPACEBOT_IMAGE_TAG=v0.4.1
# Fill in with the sha256 digest. Update on every release.
# Find via: docker manifest inspect ghcr.io/jrmatherly/spacebot:v0.4.1 | jq -r '.config.digest'
SPACEBOT_IMAGE_DIGEST=sha256:REPLACE_ME

# ========================================
# Optional: loopback by default
# ========================================
# SPACEBOT_BIND=127.0.0.1

# ========================================
# Optional: model selection overrides
# ========================================
# SPACEBOT_MODEL=anthropic/claude-opus-4-6
# SPACEBOT_CHANNEL_MODEL=anthropic/claude-sonnet-4-6
# SPACEBOT_WORKER_MODEL=anthropic/claude-haiku-4-5
# SPACEBOT_VOICE_MODEL=openai/gpt-4o-realtime

# ========================================
# Optional: logging
# ========================================
RUST_LOG=info

# ========================================
# Optional: timezone
# ========================================
# SPACEBOT_CRON_TIMEZONE=America/New_York
# SPACEBOT_USER_TIMEZONE=America/New_York

# ========================================
# Optional: messaging adapters
# ========================================
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# TELEGRAM_BOT_TOKEN=
# MATTERMOST_URL=
# MATTERMOST_BOT_TOKEN=
# SIGNAL_PHONE_NUMBER=
# SIGNAL_DAEMON_URL=

# ========================================
# Spacedrive profile — REQUIRED if profile active
# ========================================
# Real Spacedrive API: a single SD_AUTH var formatted "user:password".
# No fallback; Compose errors out if unset when the spacedrive profile runs.
# SD_AUTH=admin:REPLACE_ME_WITH_A_REAL_PASSWORD

# ========================================
# Observability profile — REQUIRED if profile active
# ========================================
# No working defaults. Compose errors out if unset.
# GF_ADMIN_USER=admin
# GF_ADMIN_PASSWORD=REPLACE_ME
# Optional: enable anonymous Viewer (off by default)
# GF_ANONYMOUS=false
