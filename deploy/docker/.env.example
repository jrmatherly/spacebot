# ========================================
# Required: at least ONE LLM provider
# ========================================
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# OPENROUTER_API_KEY=sk-or-...
# (See docs/ for the full provider list)

# ========================================
# Spacebot image (digest-pinned)
# ========================================
# Tag kept as a human reference. Compose uses the digest below.
# Bump both on every release; the release-tag.sh workflow does NOT touch
# this file. Find the digest after the release workflow finishes building:
#   docker manifest inspect ghcr.io/jrmatherly/spacebot:v0.6.0 | jq -r '.config.digest'
SPACEBOT_IMAGE_TAG=v0.6.0
SPACEBOT_IMAGE_DIGEST=sha256:REPLACE_ME

# ========================================
# Optional: loopback by default
# ========================================
# SPACEBOT_BIND=127.0.0.1

# ========================================
# Optional: model selection overrides
# ========================================
# SPACEBOT_MODEL=anthropic/claude-opus-4-6
# SPACEBOT_CHANNEL_MODEL=anthropic/claude-sonnet-4-6
# SPACEBOT_WORKER_MODEL=anthropic/claude-haiku-4-5
# SPACEBOT_VOICE_MODEL=openai/gpt-4o-realtime

# ========================================
# Optional: logging
# ========================================
RUST_LOG=info

# ========================================
# Optional: timezone
# ========================================
# SPACEBOT_CRON_TIMEZONE=America/New_York
# SPACEBOT_USER_TIMEZONE=America/New_York

# ========================================
# Optional: messaging adapters
# ========================================
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# TELEGRAM_BOT_TOKEN=
# MATTERMOST_URL=
# MATTERMOST_BOT_TOKEN=
# SIGNAL_PHONE_NUMBER=
# SIGNAL_DAEMON_URL=

# ========================================
# Spacedrive profile — REQUIRED if profile active
# ========================================
# Real Spacedrive API: a single SD_AUTH var formatted "user:password".
# No fallback; Compose errors out if unset when the spacedrive profile runs.
# SD_AUTH=admin:REPLACE_ME_WITH_A_REAL_PASSWORD

# ========================================
# Observability profile — REQUIRED if profile active
# ========================================
# No working defaults. Compose errors out if unset.
# GF_ADMIN_USER=admin
# GF_ADMIN_PASSWORD=REPLACE_ME
# Optional: enable anonymous Viewer (off by default)
# GF_ANONYMOUS=false

# ========================================
# LiteLLM profile — REQUIRED if profile active
# ========================================
# Two distinct keys matter; never conflate them:
#   - LITELLM_MASTER_KEY  admin credential for the proxy itself. Used to
#                         create virtual API keys via /key/generate. Only
#                         the proxy operator holds this. Never configure
#                         Spacebot with this key.
#   - LITELLM_API_KEY     a virtual API key created via /key/generate,
#                         scoped to a user/team/budget. This is what
#                         Spacebot uses as api_key in its
#                         [llm.providers.litellm] config block. Issued
#                         after the stack is running, not ahead of time.
#
# First-boot flow:
#   1. Set LITELLM_MASTER_KEY below + at least one upstream key.
#   2. `just compose-up-litellm` — starts proxy + Spacebot.
#   3. curl -X POST http://localhost:4000/key/generate \
#        -H "Authorization: Bearer $LITELLM_MASTER_KEY" \
#        -H "Content-Type: application/json" \
#        -d '{"models":["claude-sonnet-4-6"],"max_budget":10.0}'
#   4. Paste the returned key into LITELLM_API_KEY below.
#   5. Add the [llm.providers.litellm] block to deploy/docker/config.toml
#      (see docs/content/docs/(configuration)/litellm.mdx).
#   6. `just compose-down && just compose-up-litellm` — reload.
#
# LITELLM_MASTER_KEY=sk-master-REPLACE_ME
# LITELLM_API_KEY=sk-virtual-REPLACE_ME_AFTER_KEY_GENERATE
#
# Upstream keys are read by the proxy, not by Spacebot, when this
# profile runs. Set whichever upstreams you plan to route through
# LiteLLM:
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
