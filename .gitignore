/target
rust_out
.DS_Store
.fastembed_cache
.build/
*.db
*.db-shm
*.db-wal

# Package manager lockfiles (bun only — never npm/pnpm/yarn)
pnpm-lock.yaml
package-lock.json
yarn.lock

# Interface
interface/node_modules/
interface/dist/
interface/public/opencode-embed/
.opencode-build-cache/

# Universal node_modules rule — catches stray caches in any subtree
# (e.g., root-level node_modules/.vite/vitest/ created when vitest is
# accidentally run from repo root instead of interface/). Idempotent
# with the path-specific rules above for grep-ability.
**/node_modules/

# SpaceUI
spaceui/node_modules
spaceui/packages/*/dist/
spaceui/packages/*/node_modules/
spaceui/examples/*/node_modules/
spaceui/examples/*/dist/
spaceui/.storybook/node_modules/
spaceui/.storybook/storybook-static/

# Spacedrive (independent workspace, build artifacts only)
spacedrive/target/
spacedrive/node_modules/
spacedrive/apps/*/node_modules/
spacedrive/packages/*/node_modules/
spacedrive/apps/*/dist/
spacedrive/packages/*/dist/

# Desktop sidecar binaries (built by scripts/bundle-sidecar.sh)
desktop/src-tauri/binaries/

.idea
list/
/agents/
.remember/
.vscode/settings.json
.scratchpad/
.full-review/

# Nix
result/
.direnv/

# Claude Code - local/personal files
.claude/settings.local.json
.claude/agent-memory*/
.claude/scheduled_tasks.lock

# Claude Code - legacy auto-generated (safe to ignore)
.claude-context
.claude-memory
.claude-decisions
docs/phases/
docs/specs/
PROJECT-STATUS.md
.worktrees/
.turbo/

# Docker Compose
deploy/docker/.env
deploy/docker/data/

# MCP team config — copy .mcp.json.example to .mcp.json to enable.
# Resolved .mcp.json stays local so env-substitution tokens (GITHUB_TOKEN, etc.)
# don't leak into git. Re-enable tracking via `!.mcp.json` if the team decides
# to commit a no-secrets variant.
.mcp.json

# Graphify (opt-in knowledge graph tool — see .scratchpad/completed/2026-04-21-graphify-research.md)
# Ignore all graphify outputs. GRAPH_REPORT.md.keep is an intentional escape
# hatch for milestone snapshots — copy GRAPH_REPORT.md to GRAPH_REPORT.md.keep
# (token header stripped via scripts/graphify-rebuild.sh --snapshot) to commit.
graphify-out/
!graphify-out/GRAPH_REPORT.md.keep
